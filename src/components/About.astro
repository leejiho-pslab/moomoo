---
import { site } from '../data/site.config';
import images from '../data/images.json';
import { img } from '../lib/img';
import { localImage } from '../lib/localImage';
const { title, body, stats, credentials, career, awards, services, process } = site.about;
const titleLines = title.split('\n');
const profileSrc = images.profile ?? localImage('profile');
const hasProfilePhoto = Boolean(img(profileSrc));
const profilePhoto = img(profileSrc) ?? `${import.meta.env.BASE_URL}images/dealer-profile.svg`;
const banners = {
  career: img(localImage('about-career')),
  services: img(localImage('about-services')),
  process: img(localImage('about-process')),
};
---

<section class="section section--dark" id="about">
  <div class="container about">
    <div class="about__intro">
      <div class="about__aside" data-reveal>
        <figure class="about__photo">
          <img src={profilePhoto} alt="딜러 프로필" loading="lazy" />
          {!hasProfilePhoto && <figcaption>{site.dealer.name} · {site.dealer.role}</figcaption>}
        </figure>
        <ul class="creds">
          {credentials.map((c) => (
            <li class="cred"><span class="cred__dot" aria-hidden="true"></span>{c}</li>
          ))}
        </ul>
      </div>

      <div class="about__head">
        <p class="eyebrow" data-reveal>ABOUT</p>
        <h2 class="headline" data-reveal data-reveal-delay="1">
          {titleLines.map((line, i) => (
            <>{line}{i < titleLines.length - 1 && <br />}</>
          ))}
        </h2>
        <p class="lead about__body" data-reveal data-reveal-delay="2">{body}</p>

        <ul class="stats" data-reveal data-reveal-delay="2">
          {stats.map((s) => (
            <li class="stat">
              <span class="stat__value">{s.value}</span>
              <span class="stat__label">{s.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="about__block">
      {banners?.career && (
        <div class="about__banner" style={`background-image:url('${banners.career}')`} data-reveal></div>
      )}
      <div class="about__blockhead" data-reveal>
        <p class="eyebrow">CAREER</p>
        <h3 class="about__blocktitle">경력 &amp; 실적</h3>
        <p class="about__blocklead">한 브랜드에 머무르지 않고 현장에서 검증된 세일즈. 숫자로 증명해 온 신뢰입니다.</p>
      </div>
      <div class="career">
        <ol class="timeline">
          {career.map((c, i) => (
            <li class="tl" data-reveal data-reveal-delay={String((i % 3) + 1)}>
              <span class="tl__dot" aria-hidden="true"></span>
              <span class="tl__period">{c.period}</span>
              <div class="tl__main">
                <h4 class="tl__brand">{c.brand}</h4>
                <p class="tl__role">{c.role}{c.note && <span class="tl__note">{c.note}</span>}</p>
              </div>
            </li>
          ))}
        </ol>
        <aside class="awards" data-reveal data-reveal-delay="1">
          <p class="awards__title">주요 수상 · 실적</p>
          <ul class="awards__list">
            {awards.map((a) => (
              <li class="award"><span class="award__ic" aria-hidden="true">★</span>{a}</li>
            ))}
          </ul>
        </aside>
      </div>
    </div>

    <div class="about__block">
      {banners?.services && (
        <div class="about__banner" style={`background-image:url('${banners.services}')`} data-reveal></div>
      )}
      <div class="about__blockhead" data-reveal>
        <p class="eyebrow">EXPERTISE</p>
        <h3 class="about__blocktitle">전문 분야</h3>
        <p class="about__blocklead">구매 상담부터 출고, 그 이후 관리까지. 한 사람이 끝까지 책임집니다.</p>
      </div>
      <ul class="services">
        {services.map((s, i) => (
          <li class="service" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <span class="service__mark" aria-hidden="true">✓</span>
            <h4 class="service__name">{s.name}</h4>
            <p class="service__desc">{s.desc}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="about__block">
      {banners?.process && (
        <div class="about__banner" style={`background-image:url('${banners.process}')`} data-reveal></div>
      )}
      <div class="about__blockhead" data-reveal>
        <p class="eyebrow">PROCESS</p>
        <h3 class="about__blocktitle">상담 프로세스</h3>
        <p class="about__blocklead">문의부터 사후관리까지, 막힘 없이 투명하게 진행됩니다.</p>
      </div>
      <ol class="process">
        {process.map((p, i) => (
          <li class="step" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <span class="step__no">{p.no}</span>
            <h4 class="step__title">{p.title}</h4>
            <p class="step__desc">{p.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .about { display: grid; gap: clamp(56px, 9vw, 110px); }

  /* ── 인트로: 프로필 + 소개 ── */
  .about__intro {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: clamp(32px, 6vw, 72px);
    align-items: start;
  }
  .about__aside { display: grid; gap: 22px; }
  .about__photo { margin: 0; position: relative; }
  .about__photo img {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--line-dark);
    box-shadow: 0 30px 60px -30px rgba(0, 170, 210, 0.5);
  }
  .about__photo figcaption {
    position: absolute; left: 16px; bottom: 16px;
    padding: 6px 14px; border-radius: 999px;
    background: rgba(0, 0, 0, 0.45); backdrop-filter: blur(6px);
    border: 1px solid var(--line-dark);
    font-size: 0.8rem; letter-spacing: 0.04em;
  }
  .creds { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
  .cred {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.92rem; color: rgba(255, 255, 255, 0.82);
    padding: 11px 16px; border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--line-dark);
  }
  .cred__dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent); flex: none;
    box-shadow: 0 0 10px 1px rgba(0, 170, 210, 0.7);
  }

  .about__head { max-width: 760px; }
  .about__body { margin-top: 22px; color: rgba(255, 255, 255, 0.66); }

  /* ── 스탯 ── */
  .stats {
    list-style: none; margin: 38px 0 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 4vw, 40px);
  }
  .stat { display: flex; flex-direction: column; gap: 6px; }
  .stat__value {
    font-size: clamp(1.9rem, 5vw, 3rem); font-weight: 800;
    letter-spacing: -0.04em;
    background: linear-gradient(120deg, #fff, var(--accent));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .stat__label { color: var(--muted-dark); font-size: 0.92rem; }

  /* ── 블록 공통 헤더 ── */
  .about__block { border-top: 1px solid var(--line-dark); padding-top: clamp(40px, 6vw, 64px); }
  .about__banner {
    position: relative;
    width: 100%; aspect-ratio: 21 / 9; border-radius: var(--radius);
    background-size: cover; background-position: center 60%;
    background-color: #10131c;
    overflow: hidden;
    border: 1px solid var(--line-dark);
    margin-bottom: clamp(24px, 4vw, 36px);
  }
  .about__banner::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(5, 7, 11, 0.1) 0%, rgba(5, 7, 11, 0.55) 70%, rgba(5, 7, 11, 0.85) 100%);
  }
  .about__blockhead { margin-bottom: clamp(28px, 4vw, 44px); max-width: 620px; }
  .about__blocktitle { font-size: clamp(1.6rem, 4vw, 2.4rem); margin-top: 12px; }
  .about__blocklead { color: var(--muted-dark); margin: 14px 0 0; font-size: 1rem; }

  /* ── 경력 & 실적 ── */
  .career {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: start;
  }
  .timeline { list-style: none; margin: 0; padding: 0; position: relative; }
  .timeline::before {
    content: ''; position: absolute; left: 6px; top: 6px; bottom: 6px;
    width: 2px; background: linear-gradient(var(--accent), rgba(0, 170, 210, 0.12));
  }
  .tl {
    position: relative; display: grid;
    grid-template-columns: 110px 1fr; gap: 4px 22px;
    padding: 0 0 26px 28px;
  }
  .tl:last-child { padding-bottom: 0; }
  .tl__dot {
    position: absolute; left: 0; top: 5px;
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--ink); border: 2px solid var(--accent);
    box-shadow: 0 0 0 4px rgba(0, 170, 210, 0.12);
  }
  .tl__period {
    grid-column: 1; font-size: 0.85rem; font-weight: 600;
    color: var(--accent); padding-top: 2px; white-space: nowrap;
  }
  .tl__main { grid-column: 2; }
  .tl__brand { font-size: 1.12rem; }
  .tl__role {
    margin: 4px 0 0; color: rgba(255, 255, 255, 0.6); font-size: 0.92rem;
    display: flex; flex-wrap: wrap; align-items: center; gap: 8px;
  }
  .tl__note {
    font-size: 0.78rem; font-weight: 600; color: var(--accent);
    padding: 3px 10px; border-radius: 999px;
    background: rgba(0, 170, 210, 0.12); border: 1px solid rgba(0, 170, 210, 0.3);
  }
  .awards {
    padding: clamp(22px, 3vw, 30px); border-radius: var(--radius);
    background: linear-gradient(160deg, rgba(0, 170, 210, 0.1), rgba(255, 255, 255, 0.03));
    border: 1px solid var(--line-dark);
  }
  .awards__title {
    margin: 0 0 16px; font-weight: 700; font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .awards__list { list-style: none; margin: 0; padding: 0; display: grid; gap: 11px; }
  .award {
    display: flex; align-items: center; gap: 11px;
    font-size: 0.94rem; color: rgba(255, 255, 255, 0.85);
  }
  .award__ic {
    flex: none; width: 24px; height: 24px; border-radius: 7px;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(0, 170, 210, 0.18); color: var(--accent); font-size: 0.78rem;
  }

  /* ── 전문 분야 ── */
  .services {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: clamp(14px, 2vw, 22px);
  }
  .service {
    padding: 26px 24px; border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--line-dark);
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease), background 0.4s var(--ease);
  }
  .service:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 170, 210, 0.45);
    background: rgba(0, 170, 210, 0.06);
  }
  .service__mark {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 10px;
    background: rgba(0, 170, 210, 0.16); color: var(--accent);
    font-weight: 800; font-size: 1rem; margin-bottom: 16px;
  }
  .service__name { font-size: 1.18rem; }
  .service__desc { color: rgba(255, 255, 255, 0.6); font-size: 0.95rem; margin: 10px 0 0; line-height: 1.65; }

  /* ── 프로세스 ── */
  .process {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(5, 1fr);
    gap: clamp(12px, 1.6vw, 20px);
    counter-reset: step;
  }
  .step { position: relative; padding-top: 26px; }
  .step::before {
    content: ''; position: absolute; top: 5px; left: 0; right: 0;
    height: 2px; background: linear-gradient(90deg, var(--accent), rgba(0, 170, 210, 0.15));
  }
  .step__no {
    display: block; font-size: 1.6rem; font-weight: 800; letter-spacing: -0.03em;
    color: var(--accent); margin-bottom: 10px;
  }
  .step__title { font-size: 1.1rem; }
  .step__desc { color: rgba(255, 255, 255, 0.55); font-size: 0.9rem; margin: 8px 0 0; line-height: 1.6; }

  /* ── 반응형 ── */
  @media (max-width: 920px) {
    .services { grid-template-columns: repeat(2, 1fr); }
    .process { grid-template-columns: repeat(2, 1fr); gap: 22px 16px; }
    .career { grid-template-columns: 1fr; }
    .about__banner { aspect-ratio: 16 / 9; }
  }
  @media (max-width: 760px) {
    .about__intro { grid-template-columns: 1fr; }
    .about__aside {
      grid-template-columns: minmax(0, 220px) 1fr;
      align-items: center; gap: 18px;
    }
    .creds { gap: 8px; }
    .cred { padding: 9px 13px; font-size: 0.84rem; }
  }
  @media (max-width: 540px) {
    /* 모바일 스크롤 단축 — 블록 간격·여백 축소 */
    .about { gap: 44px; }
    .about__block { padding-top: 36px; }
    .about__blockhead { margin-bottom: 22px; }

    /* 프로필 사진 + 자격 뱃지(2열) */
    .about__aside { grid-template-columns: 1fr; }
    .about__photo { max-width: 220px; }
    .creds { grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .cred { padding: 9px 11px; font-size: 0.8rem; }

    /* 스탯 */
    .stats { grid-template-columns: 1fr; gap: 14px; margin-top: 28px; }
    .stat { flex-direction: row; align-items: baseline; gap: 14px; }

    /* 경력 타임라인 */
    .tl { grid-template-columns: 1fr; gap: 2px; padding-bottom: 20px; }
    .tl__period, .tl__main { grid-column: 1; }

    /* 수상·실적 2열 압축 */
    .awards { padding: 18px; }
    .awards__list { grid-template-columns: repeat(2, 1fr); gap: 9px 12px; }
    .award { font-size: 0.84rem; gap: 9px; }

    /* 전문 분야 2열 압축 */
    .services { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .service { padding: 16px 14px; }
    .service__mark { width: 28px; height: 28px; margin-bottom: 10px; font-size: 0.9rem; }
    .service__name { font-size: 0.98rem; }
    .service__desc { font-size: 0.8rem; margin-top: 7px; line-height: 1.55; }

    /* 프로세스 2열 압축 */
    .process { grid-template-columns: repeat(2, 1fr); gap: 18px 14px; }
    .step__no { font-size: 1.4rem; margin-bottom: 7px; }
    .step__title { font-size: 1rem; }
    .step__desc { font-size: 0.82rem; }
  }
</style>
