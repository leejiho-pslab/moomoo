---
import { site } from '../data/site.config';
import images from '../data/images.json';
import { img } from '../lib/img';
import { localImage } from '../lib/localImage';
const { title, description, items } = site.models;
const carSilhouette = `${import.meta.env.BASE_URL}images/car-silhouette.svg`;
const modelPhotos: Record<string, string | null> = images.models ?? {};
---

<section class="section" id="models">
  <div class="container">
    <div class="section__head">
      <p class="eyebrow" data-reveal>LINEUP</p>
      <h2 class="headline" data-reveal data-reveal-delay="1">{title}</h2>
      <p class="lead" data-reveal data-reveal-delay="2">{description}</p>
    </div>

    <div class="models">
      {items.map((m, i) => {
        const photo = img(modelPhotos[m.id] ?? localImage(`model-${m.id}`) ?? m.image);
        return (
        <a
          class="model"
          href={m.href}
          target="_blank"
          rel="noopener"
          data-reveal
          data-reveal-delay={String((i % 3) + 1)}
        >
          <div
            class="model__media"
            data-variant={String(i % 4)}
            data-photo={photo ? 'true' : undefined}
          >
            <img
              class="model__car"
              src={carSilhouette}
              alt=""
              aria-hidden="true"
              loading="lazy"
            />
            {photo && (
              <img
                class="model__photo"
                src={photo}
                alt={m.name}
                loading="lazy"
                onerror="this.remove()"
              />
            )}
            <span class="model__segment">{m.segment}</span>
          </div>
          <div class="model__body">
            <h3 class="model__name">{m.name}</h3>
            <p class="model__tagline">{m.tagline}</p>
            <span class="model__link">자세히 보기 <span aria-hidden="true">→</span></span>
          </div>
        </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .models {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2.4vw, 28px);
  }
  .model {
    display: flex; flex-direction: column;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--paper);
    border: 1px solid var(--line);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease),
      border-color 0.4s var(--ease);
  }
  .model:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 50px -28px rgba(0, 44, 95, 0.45);
    border-color: rgba(0, 170, 210, 0.4);
  }
  .model__media {
    position: relative;
    aspect-ratio: 16 / 10;
    background-size: cover; background-position: center;
    display: flex; align-items: flex-start;
  }
  /* 이미지 없을 때 차급별 그라디언트 비주얼 */
  .model__media[data-variant='0'] { background-image: linear-gradient(135deg, #0a2540, #00aad2); }
  .model__media[data-variant='1'] { background-image: linear-gradient(135deg, #1a1c22, #3a4150); }
  .model__media[data-variant='2'] { background-image: linear-gradient(135deg, #002c5f, #0a8bb0); }
  .model__media[data-variant='3'] { background-image: linear-gradient(135deg, #11141a, #2a3340); }
  .model__media::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(120% 80% at 80% 0%, rgba(255,255,255,0.18), transparent 60%);
  }
  /* 실제 차량 사진: 밝은 배경 위에 잘리지 않게 전체 표시(contain).
     사진 로드 실패 시 onerror 로 제거되어 뒤의 실루엣이 노출된다. */
  .model__media[data-photo] { background-color: #eef1f5; }
  .model__media[data-photo]::after { display: none; }
  .model__photo {
    position: absolute; inset: 0; z-index: 0;
    width: 100%; height: 100%;
    object-fit: contain; object-position: center 56%;
    background: #eef1f5;
    transition: transform 0.5s var(--ease);
  }
  .model:hover .model__photo { transform: scale(1.04); }
  .model__car {
    position: absolute;
    left: 50%; top: 56%;
    transform: translate(-50%, -50%);
    width: 86%;
    filter: drop-shadow(0 14px 22px rgba(0, 0, 0, 0.35));
    transition: transform 0.5s var(--ease);
  }
  .model:hover .model__car { transform: translate(-50%, -50%) scale(1.05); }
  .model__segment {
    position: relative; z-index: 1;
    margin: 16px; padding: 6px 12px;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em;
    color: #fff; background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px; backdrop-filter: blur(6px);
  }
  .model__body { padding: 22px 22px 26px; display: flex; flex-direction: column; gap: 6px; }
  .model__name { font-size: 1.3rem; }
  .model__tagline { color: var(--muted); font-size: 0.96rem; margin: 0; }
  .model__link {
    margin-top: 14px; font-weight: 600; font-size: 0.92rem; color: var(--accent-deep);
  }
  .model:hover .model__link span { display: inline-block; transform: translateX(4px); transition: transform 0.3s var(--ease); }

  /* 모바일에서도 2열 유지 — 세로 스크롤 절감 */
  @media (max-width: 880px) {
    .models { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .model__body { padding: 14px 14px 18px; }
    .model__name { font-size: 1.05rem; }
    .model__tagline { font-size: 0.84rem; }
    .model__link { margin-top: 8px; font-size: 0.82rem; }
    .model__segment { margin: 10px; padding: 4px 9px; font-size: 0.62rem; }
  }
</style>
