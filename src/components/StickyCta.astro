---
import { site } from '../data/site.config';
const { phone, kakaoUrl } = site.contact;
const digits = phone.replace(/[^0-9+]/g, '');
const telHref = `tel:${digits}`;
const smsHref = `sms:${digits}`;
const hasKakao = Boolean(kakaoUrl);
---

<div class="sticky-cta" aria-label="빠른 상담">
  <a class="sticky-cta__btn sticky-cta__btn--tel" href={telHref}>
    <span aria-hidden="true">📞</span> 전화 상담
  </a>
  {hasKakao ? (
    <a class="sticky-cta__btn sticky-cta__btn--kakao" href={kakaoUrl} target="_blank" rel="noopener">
      <span aria-hidden="true">💬</span> 카카오톡
    </a>
  ) : (
    <a class="sticky-cta__btn sticky-cta__btn--sms" href={smsHref}>
      <span aria-hidden="true">✉️</span> 문자 상담
    </a>
  )}
</div>

<style>
  .sticky-cta { display: none; }
  @media (max-width: 880px) {
    .sticky-cta {
      position: fixed; inset: auto 0 0 0; z-index: 90;
      display: flex; gap: 10px;
      padding: 10px 14px calc(10px + env(safe-area-inset-bottom));
      background: rgba(10, 10, 12, 0.86);
      backdrop-filter: blur(16px);
      border-top: 1px solid var(--line-dark);
    }
    .sticky-cta__btn {
      flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px;
      min-height: 50px; border-radius: 12px; font-weight: 700; font-size: 1rem;
    }
    .sticky-cta__btn--tel { background: var(--accent); color: #04222b; }
    .sticky-cta__btn--kakao { background: #fae100; color: #3a1d1d; }
    .sticky-cta__btn--sms { background: #fff; color: #04222b; }
  }
</style>
