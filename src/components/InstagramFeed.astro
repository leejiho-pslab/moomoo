---
import { site } from '../data/site.config';
import feed from '../data/feed.json';

const { title, description, profileUrl } = site.instagram;
const posts = (feed.instagram ?? []).slice(0, 6);
const placeholders = Array.from({ length: 6 }, (_, i) => i);
---

<section class="section" id="instagram">
  <div class="container">
    <div class="section__head section__head--row">
      <div>
        <p class="eyebrow" data-reveal>INSTAGRAM</p>
        <h2 class="headline" data-reveal data-reveal-delay="1">{title}</h2>
        <p class="lead" data-reveal data-reveal-delay="2">{description}</p>
      </div>
      <a class="btn btn--solid-dark ig__profile" href={profileUrl} target="_blank" rel="noopener" data-reveal>
        프로필 보기
      </a>
    </div>

    {posts.length > 0 ? (
      <div class="ig-grid">
        {posts.map((p, i) => (
          <a class="ig-cell" href={p.permalink} target="_blank" rel="noopener" data-reveal data-reveal-delay={String((i % 4) + 1)}>
            <img src={p.thumbnailUrl} alt={p.caption || '인스타그램 게시물'} loading="lazy" />
            {p.mediaType === 'VIDEO' && <span class="ig-cell__badge" aria-hidden="true">▶</span>}
            {p.caption && <span class="ig-cell__cap">{p.caption}</span>}
          </a>
        ))}
      </div>
    ) : (
      <a class="ig-grid ig-grid--empty" href={profileUrl} target="_blank" rel="noopener">
        {placeholders.map((i) => (
          <span class="ig-cell ig-cell--ph" data-variant={String(i % 4)} data-reveal data-reveal-delay={String((i % 4) + 1)} />
        ))}
      </a>
    )}
  </div>
</section>

<style>
  .ig__profile { flex: none; }
  .ig-grid {
    display: grid; grid-template-columns: repeat(6, 1fr);
    gap: clamp(8px, 1.2vw, 14px);
  }
  .ig-cell {
    position: relative; aspect-ratio: 1; border-radius: 14px; overflow: hidden;
    background: var(--paper-dim); display: block;
  }
  .ig-cell img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease); }
  .ig-cell:hover img { transform: scale(1.07); }
  .ig-cell__badge {
    position: absolute; top: 10px; right: 10px; color: #fff;
    text-shadow: 0 1px 6px rgba(0,0,0,0.6); font-size: 0.9rem;
  }
  .ig-cell__cap {
    position: absolute; inset: 0; padding: 14px;
    display: flex; align-items: flex-end;
    font-size: 0.82rem; color: #fff; line-height: 1.4;
    background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.66));
    opacity: 0; transition: opacity 0.3s var(--ease);
    overflow: hidden;
  }
  .ig-cell:hover .ig-cell__cap { opacity: 1; }

  .ig-cell--ph[data-variant='0'] { background: linear-gradient(135deg, #dfe6ee, #b9c6d6); }
  .ig-cell--ph[data-variant='1'] { background: linear-gradient(135deg, #cfe6ee, #9fc6d6); }
  .ig-cell--ph[data-variant='2'] { background: linear-gradient(135deg, #e6e9ee, #c4ccd8); }
  .ig-cell--ph[data-variant='3'] { background: linear-gradient(135deg, #d3e3ef, #aac4dc); }

  @media (max-width: 880px) {
    .section__head--row { flex-direction: column; align-items: flex-start; gap: 16px; }
    .ig-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
